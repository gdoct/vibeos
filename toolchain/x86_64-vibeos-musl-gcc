#!/bin/sh
#
# x86_64-vibeos-musl-gcc — the VibeOS cross compiler (ROADMAP §"Toolchain
# integration"). A thin wrapper that drives a stock host gcc with the VibeOS
# specs file (generated by mksysroot.sh), so compilation and linking target the
# VibeOS sysroot — its headers, its musl libc + crt objects, and its dynamic
# linker at /lib/ld-musl-x86_64.so.1 — instead of repurposing host musl flags.
#
# Usage is exactly like gcc:
#   x86_64-vibeos-musl-gcc -O2 -o hello hello.c            # dynamic
#   x86_64-vibeos-musl-gcc -static -O2 -o hello hello.c    # static
#
# Override the underlying compiler with REALGCC=... (e.g. a real cross gcc).

HERE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SPECS="$HERE/vibeos.specs"

if [ ! -f "$SPECS" ]; then
    echo "x86_64-vibeos-musl-gcc: sysroot not built; run $HERE/mksysroot.sh first" >&2
    exit 1
fi

exec "${REALGCC:-gcc}" "$@" -specs "$SPECS"
