# git ignore for c/c++ projects
# Compiled Object files
*.o
*.so
*.exe
*.dll
*.out
*.a
*.dylib
# Precompiled Headers
*.gch
# Compiled Dynamic libraries
*.dll
*.so
*.dylib
# For Visual Studio
*.vcxproj.user
*.suo
*.ncb
*.sdf
*.opensdf
*.cache
*.ilk
*.pdb
*.idb
*.ipch
*.aps
*.pch
*.res
*.obj
*.log
*.tlog
*.lastbuildstate
*.vspscc
*.vssscc
*.scc
# For Code::Blocks      
*.depend
*.layout
*.cbp
*.workspace

build/
bin/
dist/
obj/
# Generated VibeOS cross-toolchain sysroot (rebuild with: make sysroot)
toolchain/sysroot/

# Package source trees (docs/pkgman.md) keep their own staged bin/ dirs, which
# the broad `bin/` rule above would otherwise ignore.
!packages/**/bin/
!packages/**/bin/**
toolchain/vibeos.specs

# host build-time font tool (binary)
gui/client/tools/genfont
vendor/